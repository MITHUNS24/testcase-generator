# ============================================
# ENVIRONMENT VARIABLES - PHASE 1 AUTH SETUP
# ============================================
# These are secrets that should NEVER be committed to git
# .env file holds configuration values that vary per environment

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority
# Get this from MongoDB Atlas dashboard after creating a cluster
MONGO_URI=mongodb+srv://your_username:your_password@cluster-name.mongodb.net/testcase-generator?retryWrites=true&w=majority

# JWT Secret Key - Used to sign and verify authentication tokens
# IMPORTANT: Use a long, random string (at least 32 characters)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long_change_this

# Server Port - Where Express server will listen
PORT=5000

# Client URL - Frontend URL for CORS (Cross-Origin Resource Sharing)
# In development: http://localhost:5173 (Vite default)
# In production: Your deployed frontend URL
CLIENT_URL=http://localhost:5173

# Node Environment
NODE_ENV=development
